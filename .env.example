APP_NAME=Telegram Command Center
ENVIRONMENT=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ADMIN_API_TOKEN=change-me-admin-token

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=telegram_center
POSTGRES_USER=telegram_center
POSTGRES_PASSWORD=change-me-postgres-password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

TIMEZONE=Asia/Shanghai

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USER_ID=
TELEGRAM_POLLING_ENABLED=true

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_API_BASE=https://api.cloudflare.com/client/v4

OPENAI_API_KEY=
OPENAI_MODEL=
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=

DEPLOY_SSH_PRIVATE_KEY_PATH=/run/secrets/deploy_key
DEPLOY_SSH_PASSWORD=
DEPLOY_DEFAULT_SSH_USER=root
DEPLOY_DEFAULT_SSH_PORT=22

PAYMENT_PROVIDER_NAME=
PAYMENT_PROVIDER_BASE_URL=
PAYMENT_PROVIDER_API_KEY=
